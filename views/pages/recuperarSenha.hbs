<section class="page login-page">
  <h2>{{titulo}}</h2>

  <p>
    Informe seu e-mail para receber as instruções de recuperação de senha.
  </p>

  {{#if erro}}
    <p class="erro">{{erro}}</p>
  {{/if}}

  {{#if sucesso}}
    <p class="sucesso">{{sucesso}}</p>
  {{/if}}

  <form action="/recuperar-senha" method="POST" class="form-usuario">
    <label for="email">E-mail</label>
    <input 
      type="email" 
      id="email" 
      name="email" 
      required
    >

    <div class="registro-acoes">
      <button type="submit" class="btn btn-novo">
        Enviar instruções
      </button>

      <a href="/login" class="btn btn-cancelar">
        Cancelar
      </a>
    </div>
  </form>
</section>