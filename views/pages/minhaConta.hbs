<section class="page minha-conta-page">
  <h2>{{titulo}}</h2>

  {{#if sucesso}}
    <p class="sucesso">{{sucesso}}</p>
  {{/if}}

  <div class="conta-grid">

    <div class="conta-card">
      <h3>Dados cadastrais</h3>

      {{#if erroDados}}
        <p class="erro">{{erroDados}}</p>
      {{/if}}

      <form action="/minha-conta/dados" method="POST" class="form-usuario">
        <label for="nome">Nome completo</label>
        <input 
          type="text" 
          id="nome" 
          name="nome" 
          value="{{usuario.nome}}"
          required
        >

        <label for="email">E-mail</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          value="{{usuario.email}}"
          required
        >

        <label for="cpf_cnpj">CPF/CNPJ</label>
        <input 
          type="text" 
          id="cpf_cnpj" 
          name="cpf_cnpj" 
          value="{{usuario.cpf_cnpj}}"
          required
        >

        <button type="submit" class="btn btn-novo">
          Salvar dados
        </button>
      </form>
    </div>

    <div class="conta-card">
      <h3>Alterar senha</h3>

      {{#if erroSenha}}
        <p class="erro">{{erroSenha}}</p>
      {{/if}}

      <form action="/minha-conta/senha" method="POST" class="form-usuario">
        <label for="senha_atual">Senha atual</label>
        <input 
          type="password" 
          id="senha_atual" 
          name="senha_atual" 
          required
        >

        <label for="nova_senha">Nova senha</label>
        <input 
          type="password" 
          id="nova_senha" 
          name="nova_senha" 
          minlength="6"
          required
        >

        <label for="confirmar_nova_senha">Confirmar nova senha</label>
        <input 
          type="password" 
          id="confirmar_nova_senha" 
          name="confirmar_nova_senha" 
          minlength="6"
          required
        >

        <button type="submit" class="btn btn-success">
          Alterar senha
        </button>
      </form>
    </div>

  </div>

  <div class="conta-card conta-pedidos">
    <div class="conta-card-header">
      <h3>Últimas compras</h3>

      <a href="/minha-conta/pedidos" class="btn btn-secondary">
        Ver histórico completo
      </a>
    </div>

    {{#if pedidos.length}}
      <table class="tabela-usuarios">
        <thead>
          <tr>
            <th>Pedido</th>
            <th>Status</th>
            <th>Total</th>
            <th>Data</th>
            <th>Ações</th>
          </tr>
        </thead>

        <tbody>
          {{#each pedidos}}
            <tr>
              <td>#{{this.id}}</td>
              <td>{{this.status}}</td>
              <td>R$ {{this.total}}</td>
              <td>{{this.criado_em}}</td>
              <td>
                <a href="/minha-conta/pedidos/{{this.id}}" class="btn btn-info">
                  Ver
                </a>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p>Você ainda não possui compras finalizadas.</p>
    {{/if}}
  </div>
</section>