<h1>Gerenciar Produtos</h1>

<p>Área disponível para Administradores e Colaboradores.</p>

<div class="d-flex gap-2 mb-4">
  <a href="/produtos/novo" class="btn btn-primary">+ Novo Produto</a>
  <a href="/" class="btn btn-secondary">Voltar</a>
</div>

{{#if produtos.length}}

  <table class="table table-striped table-bordered align-middle">
    <thead class="table-dark">
      <tr>
        <th>Imagem</th>
        <th>Nome</th>
        <th>Quantidade</th>
        <th>Valor</th>
        <th>Status</th>
        <th width="220">Ações</th>
      </tr>
    </thead>

    <tbody>
      {{#each produtos}}
        <tr>
          <td>
      {{#if this.imagem}}
  <img 
    src="/{{this.imagem}}" 
    alt="{{this.nome}}" 
    style="width: 70px; height: 70px; object-fit: cover;"
  >
{{else}}
  <span class="text-muted">Sem imagem</span>
{{/if}}
          </td>

          <td>{{this.nome}}</td>

          <td>{{this.quantidade}}</td>

          <td>R$ {{this.valor}}</td>

          <td>
            {{#if this.ativo}}
              <span class="badge bg-success">Ativo</span>
            {{else}}
              <span class="badge bg-secondary">Inativo</span>
            {{/if}}
          </td>

          <td>
            <div class="d-flex gap-2">
              <a href="/produtos/editar/{{this.id}}" class="btn btn-sm btn-warning">
                Editar
              </a>

              <form action="/produtos/excluir/{{this.id}}" method="POST">
                <button type="submit" class="btn btn-sm btn-danger">
                  Excluir
                </button>
              </form>
            </div>
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>

{{else}}

  <div class="alert alert-info">
    Nenhum produto cadastrado ainda.
  </div>

{{/if}}