<div id="carouselInstitucional" class="carousel slide carousel-institucional" data-bs-ride="carousel">
  <div class="carousel-inner">

    <div class="carousel-item active">
      <img src="/img/{{pastaImagem}}/foto1.jpg" class="d-block w-100" alt="Foto 1">
    </div>

    <div class="carousel-item">
      <img src="/img/{{pastaImagem}}/foto2.jpg" class="d-block w-100" alt="Foto 2">
    </div>

    <div class="carousel-item">
      <img src="/img/{{pastaImagem}}/foto3.jpg" class="d-block w-100" alt="Foto 3">
    </div>

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#carouselInstitucional" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#carouselInstitucional" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>